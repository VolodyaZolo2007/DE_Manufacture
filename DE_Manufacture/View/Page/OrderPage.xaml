<Page x:Class="DE_Manufacture.View.Page.OrderPaGe"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DE_Manufacture.View.Page"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="1560"
      Title="OrderPaGe">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition Height="20" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Button Name="AddOrderBtn" Grid.Column="0" Content="Добавить"
                    Click="AddOrderBtn_Click"/>
            <Button Name="EditOrder" 
                Grid.Column="2"
                Content="Редактировать" Click="EditOrder_Click"
                />
            <Button Name="RemoveOrder" Grid.Column="4"
                Content="Удалить" Click="RemoveOrder_Click"
               />

            <TextBlock Grid.Column="8" Text="Поиск"/>
            <TextBox Name="SearchTb" Grid.Column="10" TextChanged="SearchTb_TextChanged"/>

           
        </Grid>
        <ListView Name="OrderLv" Grid.Row="2" >
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Номер заказа"
                                DisplayMemberBinding="{Binding Number}"/>
                    <GridViewColumn Header="Дата заказа"
                                DisplayMemberBinding="{Binding Date,StringFormat=dd-MM-yyyy}"/>
                    <GridViewColumn Header="Стоимость"
                                DisplayMemberBinding="{Binding TotalPrice}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>
