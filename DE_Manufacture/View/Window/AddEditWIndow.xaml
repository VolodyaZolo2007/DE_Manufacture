<Window x:Class="DE_Manufacture.View.Window.AddEditWIndow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DE_Manufacture.View.Window"
        mc:Ignorable="d"
        Title="Добавить/редактировать данные компании" SizeToContent="WidthAndHeight"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Text="ФИО:"/>
        <TextBox x:Name="NameTB" Grid.Row="0" Grid.Column="2" 
                 Text="{Binding Name}"/>

        <TextBlock Grid.Row="2" Text="ИНН:" />
        <TextBox x:Name="InsuranceTb" Grid.Row="2" Grid.Column="2"
                  Text="{Binding Insurance}"/>

        <TextBlock Grid.Row="4" Text="Телефон:"/>
        <TextBox x:Name="PhoneTb" Grid.Row="4" Grid.Column="2"
                 Text="{Binding Phone}"/>

        <TextBlock Grid.Row="6" Text="Адрес:"/>
        <TextBox x:Name="AddresTb" Grid.Row="6" Grid.Column="2"
                 Text="{Binding Address}"/>

        <CheckBox x:Name="IsCustomerCb" Grid.Row="8" Grid.Column="2"
                  Content="Покупатель"
                  IsChecked="{Binding IsCustomer}"/>
        
        <CheckBox x:Name="IsManufactureCb" Grid.Row="10" Grid.Column="2"
                  Content="Производитель"
                  IsChecked="{Binding IsManufacturer}"/>
<!--ff-->
        <!--аа-->
        <Button x:Name="EditCompanyBtn" Grid.Row="12" Grid.Column="2"
                 Visibility="Hidden" Click="EditCompanyBtn_Click" Content="Редактировать"/>

        <Button x:Name="AddCompanyBtn" Grid.Row="12" Grid.Column="2"
                 Click="AddCompanyBtn_Click" Content="Добавить компанию"/>
    </Grid>
</Window>
